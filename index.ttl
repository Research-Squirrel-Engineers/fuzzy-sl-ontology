@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix ns1: <http://fuzzy-sl.squirrel.link/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1: a owl:Ontology ;
    rdfs:label "Fuzzy Spatial Locations Ontology"@en ;
    owl:imports <http://www.opengis.net/ont/geosparql>,
        <http://www.w3.org/ns/prov-o-20130430> ;
    owl:versionInfo "2026-04-14" .

ns1:AcM a owl:AnnotationProperty ;
    rdfs:label "Activity Metadata"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:boolean .

ns1:AgM a owl:AnnotationProperty ;
    rdfs:label "Agent Metadata"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:boolean .

ns1:AncientLocation a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Ancient Location"@en .

ns1:AncientRegion a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Ancient Region"@en .

ns1:ArchaeologicalSite a ns1:SiteType,
        ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Archaeological Site"@en .

ns1:Bight a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Bight"@en .

ns1:Book a ns1:SourceType,
        owl:NamedIndividual ;
    rdfs:label "Book"@en .

ns1:CM a owl:AnnotationProperty ;
    rdfs:label "Coordinate Metadata (CM)"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:boolean .

ns1:CampanianIgnimbriteProject a ns1:Project,
        owl:NamedIndividual ;
    rdfs:label "Campanian Ignimbrite"@en .

ns1:Cave a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Cave"@en .

ns1:Coinhoards a ns1:Source,
        owl:NamedIndividual ;
    rdfs:label "Coinhoards"@en .

ns1:CrotonProject a ns1:Project,
        owl:NamedIndividual ;
    rdfs:label "Silver Coinage of Croton"@en .

ns1:EM a owl:AnnotationProperty ;
    rdfs:label "Entity Metadata"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:boolean .

ns1:ExternalRepository a ns1:MethodType,
        owl:NamedIndividual ;
    rdfs:label "External Repository"@en .

ns1:GLM a owl:AnnotationProperty ;
    rdfs:label "Geolocation Metadata (GLM)"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:boolean .

ns1:GeoM a owl:AnnotationProperty ;
    rdfs:label "Geometry Metadata"@en ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:boolean .

ns1:GeologicalSite a ns1:SiteType,
        owl:NamedIndividual ;
    rdfs:label "Geological Site"@en .

ns1:Georeferencing a ns1:MethodType,
        owl:NamedIndividual ;
    rdfs:label "Georeferencing"@en .

ns1:Image a ns1:SourceType,
        owl:NamedIndividual ;
    rdfs:label "Image"@en .

ns1:InhabitedPlace a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "inhabited Place"@en .

ns1:Island a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Island"@en .

ns1:Lake a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Lake"@en .

ns1:ModernRegion a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Modern Region"@en .

ns1:Mountain a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Mountain"@en .

ns1:OSM a ns1:MethodType,
        owl:NamedIndividual ;
    rdfs:label "OSM"@en .

ns1:Paper a ns1:SourceType,
        owl:NamedIndividual ;
    rdfs:label "Scientific Paper"@en .

ns1:PaperDesc a ns1:Source,
        owl:NamedIndividual ;
    rdfs:label "Description in Paper"@en .

ns1:Plateau a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Plateau"@en .

ns1:Pleiades a ns1:Source,
        owl:NamedIndividual ;
    rdfs:label "Pleiades"@en .

ns1:RegionCentre a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Region Centre"@en .

ns1:RepresentativePoint a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Representative Point"@en .

ns1:River a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "River"@en .

ns1:Sink a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Sink"@en .

ns1:Site a owl:Class ;
    rdfs:label "Site"@en ;
    rdfs:subClassOf ns1:Location .

ns1:Supervolcano a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Supervolcano"@en .

ns1:URI a ns1:SourceType,
        owl:NamedIndividual .

ns1:UnknownCategory a ns1:SpatialType,
        owl:NamedIndividual ;
    rdfs:label "Unknown Category"@en .

ns1:Website a ns1:SourceType,
        owl:NamedIndividual ;
    rdfs:label "Website"@en .

ns1:WikimediaCommons a ns1:Source,
        owl:NamedIndividual ;
    rdfs:label "Wikimedia Commons"@en .

ns1:activityDesc a owl:DatatypeProperty ;
    rdfs:label "activity method description"@en ;
    rdfs:domain ns1:Place ;
    rdfs:range xsd:string ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P15> .

ns1:certaintyDesc a owl:DatatypeProperty ;
    rdfs:label "certainty description"@en ;
    rdfs:subPropertyOf owl:topDataProperty ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P13> .

ns1:certaintyLevel a owl:ObjectProperty ;
    rdfs:label "certainty level"@en ;
    rdfs:domain ns1:Place ;
    rdfs:range ns1:CertaintyType ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P5> .

ns1:dubiousMatch a owl:ObjectProperty ;
    rdfs:label "has a dubious match"@en ;
    rdfs:subPropertyOf skos:relatedMatch ;
    skos:definition "the match is dubious (e.g. ambiguity)"@en .

ns1:georeferencingBy a owl:ObjectProperty ;
    rdfs:label "georeferencing done by"@en ;
    rdfs:domain ns1:Place ;
    rdfs:range foaf:Person .

ns1:hasLocationType a owl:ObjectProperty ;
    rdfs:label "has location type"@en ;
    rdfs:range ns1:LocationType ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P24> .

ns1:hasPointType a owl:ObjectProperty ;
    rdfs:label "has point type"@en ;
    rdfs:range ns1:PointType ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P33> .

ns1:hasReference a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "has reference"@en ;
    ns1:EM true ;
    ns1:GLM true ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P11>,
        <https://fuzzy-sl.wikibase.cloud/entity/P17>,
        <https://fuzzy-sl.wikibase.cloud/entity/P25>,
        <https://fuzzy-sl.wikibase.cloud/entity/P31> .

ns1:hasSourceTypeDetail a owl:ObjectProperty ;
    rdfs:label "has source type (detail)"@en ;
    rdfs:subPropertyOf ns1:hasSourceType ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P16> .

ns1:high a ns1:CertaintyType,
        owl:NamedIndividual ;
    rdfs:label "high"@en .

ns1:iDAIgazetteer a ns1:Source,
        owl:NamedIndividual ;
    rdfs:label "iDAI.gazetter"@en .

ns1:image a owl:ObjectProperty ;
    rdfs:label "has image"@en .

ns1:locatedInAdministrativeEntity a owl:ObjectProperty ;
    rdfs:label "located in the administrative territorial entity"@en ;
    ns1:EM true ;
    ns1:GLM true ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P32> .

ns1:low a ns1:CertaintyType,
        owl:NamedIndividual ;
    rdfs:label "low"@en .

ns1:medium a ns1:CertaintyType,
        owl:NamedIndividual ;
    rdfs:label "medium"@en .

ns1:method a owl:ObjectProperty ;
    rdfs:label "georeferencing method"@en ;
    rdfs:domain ns1:Place ;
    rdfs:range ns1:MethodType .

ns1:methodUsed a owl:ObjectProperty ;
    rdfs:subPropertyOf rdf:type ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P7> .

ns1:partOf a owl:ObjectProperty ;
    rdfs:label "part of"@en ;
    ns1:EM true ;
    ns1:GLM true ;
    rdfs:domain ns1:Place ;
    rdfs:range ns1:Project ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P3> .

ns1:partlyMatch a owl:ObjectProperty ;
    rdfs:label "has partly match"@en ;
    rdfs:subPropertyOf skos:relatedMatch ;
    skos:definition "is used to state an associative mapping link between two places, in which one is part of another"@en .

ns1:precision a owl:DatatypeProperty ;
    rdfs:label "precision"@en .

ns1:relatedTo a owl:ObjectProperty ;
    rdfs:label "related to"@en ;
    rdfs:domain ns1:Place ;
    rdfs:range owl:Thing .

ns1:representativeGeometry a owl:ObjectProperty ;
    rdfs:label "representative Geometry"@en ;
    rdfs:comment "e.g. centre point"@en ;
    rdfs:subPropertyOf geo:hasGeometry .

ns1:siteType a owl:ObjectProperty ;
    rdfs:label "has site type"@en ;
    ns1:EM true ;
    ns1:GLM true ;
    rdfs:domain ns1:Place ;
    rdfs:range ns1:SiteType ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P1> .

ns1:spatialCloseMatch a owl:ObjectProperty ;
    rdfs:label "has a spatial close match"@en ;
    rdfs:subPropertyOf skos:relatedMatch ;
    skos:definition "is used to state an associative mapping link between two places, which are spatially close to each other"@en .

ns1:spatialType a owl:ObjectProperty ;
    rdfs:label "has spatial type"@en ;
    ns1:EM true ;
    ns1:GLM true ;
    rdfs:domain ns1:Place ;
    rdfs:range ns1:SpatialType ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P8> .

ns1:uncertain a ns1:CertaintyType,
        owl:NamedIndividual ;
    rdfs:label "uncertain"@en .

ns1:Location a owl:Class ;
    rdfs:label "Location"@en ;
    rdfs:subClassOf prov:Location .

ns1:LocationType a owl:Class ;
    rdfs:label "Location Type"@en ;
    rdfs:subClassOf ns1:Type .

ns1:PointType a owl:Class ;
    rdfs:label "Point Type"@en ;
    rdfs:subClassOf ns1:Type .

ns1:hasSource a owl:ObjectProperty ;
    rdfs:label "has source"@en ;
    rdfs:domain ns1:Place ;
    rdfs:range ns1:Source .

ns1:hasSourceType a owl:ObjectProperty ;
    rdfs:label "has source type (generic)"@en ;
    rdfs:subPropertyOf ns1:hasSource ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P6> .

ns1:Project a owl:Class ;
    rdfs:label "Project"@en ;
    rdfs:subClassOf prov:Activity .

ns1:SiteType a owl:Class ;
    rdfs:label "Site Type"@en ;
    rdfs:subClassOf ns1:Type .

ns1:MethodType a owl:Class ;
    rdfs:label "Method Type"@en ;
    rdfs:subClassOf ns1:Type .

ns1:CertaintyType a owl:Class ;
    rdfs:label "Certainty Type"@en ;
    rdfs:subClassOf ns1:Type .

ns1:SourceType a owl:Class ;
    rdfs:label "Source Type"@en ;
    rdfs:subClassOf ns1:Type .

ns1:Source a owl:Class ;
    rdfs:label "Source"@en .

ns1:Type a owl:Class ;
    rdfs:label "Type"@en .

ns1:Place a owl:Class ;
    rdfs:label "Place"@en ;
    rdfs:subClassOf geo:SpatialObject .

ns1:SpatialType a owl:Class ;
    rdfs:label "Spatial Type"@en ;
    rdfs:subClassOf ns1:Type .

