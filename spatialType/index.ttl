@prefix ns1: <http://fuzzy-sl.squirrel.link/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:spatialType a owl:ObjectProperty ;
    rdfs:label "has spatial type"@en ;
    ns1:EM true ;
    ns1:GLM true ;
    rdfs:domain ns1:Place ;
    rdfs:range ns1:SpatialType ;
    owl:equivalentProperty <https://fuzzy-sl.wikibase.cloud/entity/P8> .

